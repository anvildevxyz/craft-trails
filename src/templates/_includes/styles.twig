{# Trails Plugin Styles #}
<style>
    /* Summary Cards */
    .trails-summary {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .trails-stat-card {
        flex: 1;
        text-align: center;
        padding: 1rem;
    }

    .trails-stat-card h3 {
        margin: 0;
        color: #667;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .trails-stat-value {
        font-size: 2rem;
        font-weight: bold;
        line-height: 1.2;
    }

    .trails-stat-value--danger {
        color: #c92;
    }

    /* Filter Bar */
    .trails-filters {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .trails-filters > div {
        flex: 0 0 auto;
    }

    .trails-filters .trails-filter-actions {
        display: flex;
        gap: 0.5rem;
    }

    /* Results Info */
    .trails-results-info {
        color: #667;
        margin-bottom: 1rem;
    }

    /* Pagination */
    .trails-pagination {
        margin-top: 1rem;
        text-align: center;
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    /* Log Detail Sections */
    .trails-section {
        margin-top: 1.5rem;
    }

    .trails-section h3 {
        margin-bottom: 0.5rem;
    }

    /* Code Display */
    .trails-code {
        font-family: monospace;
        font-size: 0.85em;
        background: #f5f5f5;
        padding: 0.125rem 0.375rem;
        border-radius: 3px;
    }

    .trails-code--block {
        display: block;
        word-break: break-all;
    }

    /* Pre-formatted JSON */
    .trails-pre {
        background: #f5f5f5;
        padding: 1rem;
        overflow-x: auto;
        border-radius: 4px;
        font-size: 0.875rem;
        margin: 0;
    }

    .trails-pre--old {
        background: #fff5f5;
    }

    .trails-pre--new {
        background: #f5fff5;
    }

    /* Changes Comparison */
    .trails-changes {
        display: flex;
        gap: 1rem;
    }

    .trails-changes > div {
        flex: 1;
    }

    .trails-changes h4 {
        margin-bottom: 0.5rem;
    }

    /* Storage Info Box */
    .trails-storage-info {
        background: #f5f5f5;
        padding: 1rem;
        border-radius: 4px;
        margin-top: 1rem;
    }

    .trails-storage-warning {
        color: #c92;
    }

    /* Maintenance Section */
    .trails-maintenance {
        background: #fff8f0;
        margin-top: 2rem;
    }

    .trails-maintenance p {
        margin-bottom: 1rem;
    }

    .trails-cli-hint {
        margin-top: 1rem;
        color: #667;
        font-size: 0.9em;
    }

    /* Export Section */
    .trails-export-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }

    .trails-export-grid-3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1.5rem;
    }

    .trails-divider {
        margin: 1.5rem 0;
        border: 0;
        border-top: 1px solid #e0e0e0;
    }

    .trails-actions {
        margin-top: 2rem;
    }

    /* Tips List */
    .trails-tips {
        margin-top: 1.5rem;
    }

    .trails-tips h3 {
        margin-bottom: 0.5rem;
    }

    .trails-tips ul {
        margin: 0;
        padding-left: 1.25rem;
    }

    .trails-tips li {
        margin-bottom: 0.25rem;
    }

    /* Settings Sections */
    .trails-settings-section {
        margin-top: 1.5rem;
    }

    .trails-settings-section p {
        color: #667;
        margin-bottom: 1rem;
    }
</style>
